{
  "name": "playwright-framework",
  "version": "1.0.0",
  "description": "Playwright + TypeScript test automation framework with Allure reporting",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:rxapps": "playwright test src/tests/rxapps",
    "test:login": "playwright test src/tests/rxapps/login.test.ts",
    "test:mfa": "playwright test src/tests/rxapps/login.test.ts -g \"MFA\" --headed",
    "test:logout": "playwright test src/tests/rxapps/logout.test.ts --headed",
    "test:e2e": "playwright test src/tests/rxapps/logout.test.ts --headed",
    "test:staging": "cross-env ENV=staging playwright test",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open",
    "report:html": "playwright show-report playwright-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "allure-commandline": "^2.42.1",
    "allure-playwright": "^3.10.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "otplib": "^12.0.1"
  }
}
